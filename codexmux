def _push_alert(alert_type: str, message: str, session: str | None = None) -> None:
    conn = _db()
    conn.execute(
        "INSERT INTO alerts (type, message, session, created_at) VALUES (?,?,?,?)",
        (alert_type, message, session, _now()),
    )
    conn.commit()
    LOG.info("alert [%s] %s: %s", alert_type, session or "-", message)


# ---------------------------------------------------------------------------
# Session management
# ---------------------------------------------------------------------------


def resolve_name(name: str) -> str:
    conn = _db()
    row = conn.execute("SELECT name FROM sessions WHERE name = ?", (name,)).fetchone()
    if row:
        return row["name"]
    rows = conn.execute("SELECT name FROM sessions WHERE name LIKE ?", (f"{name}%",)).fetchall()
    if len(rows) == 1:
        return rows[0]["name"]
    if len(rows) > 1:
        names = ", ".join(r["name"] for r in rows)
        raise SystemExit(f"Ambiguous name '{name}', matches: {names}")
    raise SystemExit(f"Session '{name}' not found")


def _ensure_codex_trust(directory: str) -> None:
    """Add directory to ~/.codex/config.toml as trusted if not already present."""
    config_path = Path.home() / ".codex" / "config.toml"
    if not config_path.exists():
        config_path.parent.mkdir(parents=True, exist_ok=True)
        config_path.write_text("")
    content = config_path.read_text()
    section_header = f'[projects."{directory}"]'
    if section_header in content:
        return
    entry = f'\n{section_header}\ntrust_level = "trusted"\n'
    config_path.write_text(content.rstrip() + "\n" + entry)
    LOG.info("Auto-trusted directory in codex config: %s", directory)


def cmd_register(args: argparse.Namespace) -> dict[str, Any]:
    conn = _db()
    name = args.name
    directory = os.path.abspath(args.dir or os.getcwd())
    full_auto = 1 if args.full_auto else 0
    model = getattr(args, "model", None)
    sandbox = getattr(args, "sandbox", None)
    now = _now()
    conn.execute(
        """INSERT INTO sessions (name, directory, full_auto, model, sandbox, status, created_at, updated_at)
           VALUES (?,?,?,?,?,?,?,?)
           ON CONFLICT(name) DO UPDATE SET
             directory=excluded.directory,
             full_auto=excluded.full_auto,
             model=excluded.model,
             sandbox=excluded.sandbox,
             updated_at=excluded.updated_at""",
        (name, directory, full_auto, model, sandbox, "stopped", now, now),
    )
    conn.commit()
    _ensure_codex_trust(directory)
    print(f"Registered session: {name}")
    return {"name": name, "directory": directory}


def _build_codex_cmd(row: dict[str, Any]) -> list[str]:
    cmd = ["codex"]
    if row.get("full_auto"):
        cmd.extend(["--full-auto"])
    if row.get("model"):
        cmd.extend(["--model", row["model"]])
    cmd.append("--no-alt-screen")
    if row.get("sandbox"):
        cmd.extend(["--sandbox", row["sandbox"]])
    cmd.extend(["--cd", row["directory"]])
    return cmd


def cmd_start(args: argparse.Namespace) -> dict[str, Any]:
    name = resolve_name(args.name)
    conn = _db()
    row = _row_dict(conn.execute("SELECT * FROM sessions WHERE name = ?", (name,)).fetchone())
    if row is None:
        raise SystemExit(f"Session '{name}' not found")

    if tmux_has_session(name):
        print(f"Session '{name}' is already running")
        return {"name": name, "status": "already_running"}

    cmd = _build_codex_cmd(row)
    prompt = getattr(args, "prompt", None)
    if prompt:
        cmd.append(prompt)

    tmux_new_session(name, cmd, cwd=row["directory"])
    now = _now()
    conn.execute(
        "UPDATE sessions SET status='running', updated_at=? WHERE name=?",
        (now, name),
    )
    conn.commit()
    print(f"Started session: {name}")
    return {"name": name, "status": "running"}


def cmd_stop(args: argparse.Namespace) -> dict[str, Any]:
    name = resolve_name(args.name)
    conn = _db()
    tmux_kill_session(name)
    now = _now()
    conn.execute(
        "UPDATE sessions SET status='stopped', updated_at=? WHERE name=?",
        (now, name),
    )
    conn.commit()
    print(f"Stopped session: {name}")
    return {"name": name, "status": "stopped"}


def cmd_update(args: argparse.Namespace) -> dict[str, Any]:
    name = resolve_name(args.name)
    conn = _db()
    row = _row_dict(conn.execute("SELECT * FROM sessions WHERE name = ?", (name,)).fetchone())
    if row is None:
        raise SystemExit(f"Session '{name}' not found")

    updates: list[str] = []
    params: list[Any] = []
    if args.dir is not None:
        directory = os.path.abspath(args.dir)
        updates.append("directory = ?")
        params.append(directory)
        _ensure_codex_trust(directory)
    if args.full_auto is not None:
        updates.append("full_auto = ?")
        params.append(1 if args.full_auto else 0)
    if args.no_full_auto:
        updates.append("full_auto = ?")
        params.append(0)
    if args.model is not None:
        updates.append("model = ?")
        params.append(args.model)
    if args.sandbox is not None:
        updates.append("sandbox = ?")
        params.append(args.sandbox)

    if not updates:
        print(f"Nothing to update for '{name}'")
        return {"name": name, "status": "unchanged"}

    updates.append("updated_at = ?")
    params.append(_now())
    params.append(name)
    conn.execute(f"UPDATE sessions SET {', '.join(updates)} WHERE name = ?", params)
    conn.commit()
    changed = ", ".join(u.split(" =")[0] for u in updates if u != "updated_at = ?")
    print(f"Updated '{name}': {changed}")
    return {"name": name, "status": "updated"}


def cmd_rm(args: argparse.Namespace) -> dict[str, Any]:
    name = resolve_name(args.name)
    conn = _db()
    if tmux_has_session(name):
        tmux_kill_session(name)
    conn.execute("DELETE FROM messages WHERE session = ?", (name,))
    conn.execute("DELETE FROM alerts WHERE session = ?", (name,))
    conn.execute("UPDATE tasks SET assignee = NULL WHERE assignee = ?", (name,))
    conn.execute("DELETE FROM sessions WHERE name = ?", (name,))
    conn.commit()
    print(f"Removed session: {name}")
    return {"name": name, "status": "removed"}


def cmd_attach(args: argparse.Namespace) -> None:
    name = resolve_name(args.name)
    if not tmux_has_session(name):
        raise SystemExit(f"Session '{name}' is not running — start it first: codexmux start {name}")
    sn = tmux_session_name(name)
    os.execvp("tmux", ["tmux", "attach-session", "-t", sn])


def cmd_peek(args: argparse.Namespace) -> dict[str, Any]:
    name = resolve_name(args.name)
    output = tmux_capture(name)
    status = _detect_status(output)
    conn = _db()
    conn.execute(
        "UPDATE sessions SET status=?, updated_at=? WHERE name=?",
        (status, _now(), name),
    )
    conn.commit()
    if not getattr(args, "json_output", False):
        print(output)
    return {"name": name, "status": status, "output": output}


def cmd_send(args: argparse.Namespace) -> dict[str, Any]:
    name = resolve_name(args.name)
    text = args.text
    tmux_send_keys(name, text)
    conn = _db()
    conn.execute(
        "INSERT INTO messages (session, role, content, created_at) VALUES (?,?,?,?)",
        (name, "user", text, _now()),
    )
    conn.commit()
    print(f"Sent to '{name}': {text}")
    return {"name": name, "sent": text}


def cmd_ls(args: argparse.Namespace) -> list[dict[str, Any]]:
    conn = _db()
    rows = _rows_list(conn.execute("SELECT * FROM sessions ORDER BY name").fetchall())
    live = set(tmux_list())
    for row in rows:
        row["live"] = row["name"] in live

    fmt = getattr(args, "format", "text")
    if fmt == "json":
        print(json.dumps(rows, indent=2))
    else:
        if not rows:
            print("No sessions registered.")
        else:
            for row in rows:
                fa = " [full-auto]" if row.get("full_auto") else ""
                lv = " (live)" if row.get("live") else ""
                mdl = f" model={row['model']}" if row.get("model") else ""
                sb = f" sandbox={row['sandbox']}" if row.get("sandbox") else ""
                print(f"  {row['name']}: {row['status']}{fa}{mdl}{sb}{lv}")
    return rows


def cmd_exec(args: argparse.Namespace) -> dict[str, Any]:
    cmd_register(args)
    result = cmd_start(args)
    prompt = getattr(args, "prompt", None)
    if prompt and not args.prompt:
        pass
    return result


# ---------------------------------------------------------------------------
# Task board
# ---------------------------------------------------------------------------


def _short_id() -> str:
    return hashlib.sha256(uuid.uuid4().bytes).hexdigest()[:8]


def cmd_board(args: argparse.Namespace) -> Any:
    sub = args.board_action
    conn = _db()

    if sub == "add":
        tid = _short_id()
        now = _now()
        conn.execute(
            "INSERT INTO tasks (id, title, status, created_at, updated_at) VALUES (?,?,?,?,?)",
            (tid, args.title, "todo", now, now),
        )
        conn.commit()
        print(f"Added task {tid}: {args.title}")
        return {"id": tid, "title": args.title}

    if sub == "claim":
        tid = args.id
        assignee = args.assignee
        now = _now()
        conn.execute(
            "UPDATE tasks SET status='claimed', assignee=?, updated_at=? WHERE id=?",
            (assignee, now, tid),
        )
        conn.commit()
        print(f"Task {tid} claimed by {assignee}")
        return {"id": tid, "assignee": assignee}

    if sub == "done":
        tid = args.id
        now = _now()
        conn.execute(
            "UPDATE tasks SET status='done', updated_at=? WHERE id=?",
            (now, tid),
        )
        conn.commit()
        print(f"Task {tid} marked done")
        return {"id": tid, "status": "done"}

    if sub == "list":
        rows = _rows_list(conn.execute("SELECT * FROM tasks ORDER BY created_at").fetchall())
        fmt = getattr(args, "format", "text")
        if fmt == "json":
            print(json.dumps(rows, indent=2))
        else:
            for row in rows:
                a = f" ({row['assignee']})" if row.get("assignee") else ""
                print(f"  [{row['status']:>7}] {row['id']} {row['title']}{a}")
        return rows

    return None


# ---------------------------------------------------------------------------
# Watchdog
# ---------------------------------------------------------------------------

_IDLE_THRESHOLD = 600  # 10 min
_APPROVAL_GRACE = 30  # 30 sec

_last_activity: dict[str, float] = {}
_waiting_since: dict[str, float] = {}


def watchdog_tick() -> None:
    conn = _db()
    rows = conn.execute("SELECT * FROM sessions WHERE status != 'stopped'").fetchall()

    for row in rows:
        row = dict(row)
        name = row["name"]

        if not tmux_has_session(name):
            conn.execute(
                "UPDATE sessions SET status='stopped', updated_at=? WHERE name=?",
                (_now(), name),
            )
            conn.commit()
            continue

        output = tmux_capture(name, lines=80)
        status = _detect_status(output)
        conn.execute(
            "UPDATE sessions SET status=?, updated_at=? WHERE name=?",
            (status, _now(), name),
        )
        conn.commit()

        now_ts = time.time()

        if status == "exited" and row.get("full_auto"):
            _push_alert("auto-restart", f"Session '{name}' exited, restarting", name)
            resume_cmd = ["codex", "resume", "--last"]
            resume_cmd.extend(["--cd", row["directory"]])
            resume_cmd.append("--full-auto")
            resume_cmd.append("--no-alt-screen")
            if row.get("model"):
                resume_cmd.extend(["--model", row["model"]])
            if row.get("sandbox"):
                resume_cmd.extend(["--sandbox", row["sandbox"]])
            tmux_kill_session(name)
            tmux_new_session(name, resume_cmd, cwd=row["directory"])
            _last_activity[name] = now_ts
            _waiting_since.pop(name, None)
            continue

        if status == "waiting" and row.get("full_auto"):
            started = _waiting_since.get(name)
            if started is None:
                _waiting_since[name] = now_ts
            elif now_ts - started >= _APPROVAL_GRACE:
                _push_alert(
                    "auto-accept",
                    f"Auto-accepting approval for '{name}'",
                    name,
                )
                tmux_send_keys(name, "y")
                _waiting_since.pop(name, None)
                _last_activity[name] = now_ts
            continue

        _waiting_since.pop(name, None)

        if status in ("working", "idle"):
            last = _last_activity.get(name, now_ts)
            if status == "working":
                _last_activity[name] = now_ts
            elif now_ts - last > _IDLE_THRESHOLD:
                _push_alert("stuck", f"Session '{name}' idle >10min", name)
                _last_activity[name] = now_ts
        else:
            _last_activity[name] = now_ts


def watchdog_loop(interval: float = 10.0) -> None:
    while True:
        try:
            watchdog_tick()
        except Exception:
            LOG.exception("watchdog error")
        time.sleep(interval)


