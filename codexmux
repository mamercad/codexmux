# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------


def _db() -> sqlite3.Connection:
    conn = getattr(_local, "conn", None)
    if conn is None:
        DATA_DIR.mkdir(parents=True, exist_ok=True)
        conn = sqlite3.connect(str(DB_PATH), check_same_thread=False)
        conn.row_factory = sqlite3.Row
        conn.execute("PRAGMA journal_mode=WAL")
        conn.execute("PRAGMA busy_timeout=5000")
        _init_schema(conn)
        _local.conn = conn
    return conn


def _init_schema(conn: sqlite3.Connection) -> None:
    conn.executescript(
        """
        CREATE TABLE IF NOT EXISTS sessions (
            name        TEXT PRIMARY KEY,
            directory   TEXT NOT NULL,
            full_auto   INTEGER NOT NULL DEFAULT 0,
            model       TEXT,
            sandbox     TEXT,
            pid         INTEGER,
            status      TEXT NOT NULL DEFAULT 'stopped',
            created_at  TEXT NOT NULL,
            updated_at  TEXT NOT NULL
        );
        CREATE TABLE IF NOT EXISTS tasks (
            id          TEXT PRIMARY KEY,
            title       TEXT NOT NULL,
            status      TEXT NOT NULL DEFAULT 'todo',
            assignee    TEXT,
            created_at  TEXT NOT NULL,
            updated_at  TEXT NOT NULL
        );
        CREATE TABLE IF NOT EXISTS messages (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            session     TEXT NOT NULL,
            role        TEXT NOT NULL,
            content     TEXT NOT NULL,
            created_at  TEXT NOT NULL
        );
        CREATE TABLE IF NOT EXISTS memory (
            key         TEXT PRIMARY KEY,
            value       TEXT NOT NULL,
            updated_at  TEXT NOT NULL
        );
        CREATE TABLE IF NOT EXISTS alerts (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            type        TEXT NOT NULL,
            message     TEXT NOT NULL,
            session     TEXT,
            created_at  TEXT NOT NULL
        );
        """
    )
    conn.commit()


def _now() -> str:
    return datetime.now(timezone.utc).isoformat()


def _row_dict(row: sqlite3.Row | None) -> dict[str, Any] | None:
    if row is None:
        return None
    return dict(row)


def _rows_list(rows: list[sqlite3.Row]) -> list[dict[str, Any]]:
    return [dict(r) for r in rows]


# ---------------------------------------------------------------------------
# Tmux helpers
# ---------------------------------------------------------------------------


def tmux_session_name(name: str) -> str:
    return f"{TMUX_PREFIX}{name}"


def tmux_has_session(name: str) -> bool:
    sn = tmux_session_name(name)
    cp = subprocess.run(
        ["tmux", "has-session", "-t", sn],
        capture_output=True,
    )
    return cp.returncode == 0


def tmux_new_session(name: str, cmd: list[str], cwd: str | None = None) -> None:
    sn = tmux_session_name(name)
    joined = " ".join(shlex.quote(c) for c in cmd)
    tmux_cmd = ["tmux", "new-session", "-d", "-s", sn]
    if cwd:
        tmux_cmd.extend(["-c", cwd])
    tmux_cmd.append(joined)
    subprocess.run(tmux_cmd, check=True, capture_output=True)


def tmux_kill_session(name: str) -> None:
    sn = tmux_session_name(name)
    subprocess.run(
        ["tmux", "kill-session", "-t", sn],
        capture_output=True,
    )


def tmux_send_keys(name: str, keys: str) -> None:
    sn = tmux_session_name(name)
    subprocess.run(
        ["tmux", "send-keys", "-t", sn, keys, "Enter"],
        check=True,
        capture_output=True,
    )


def tmux_capture(name: str, lines: int = 200) -> str:
    sn = tmux_session_name(name)
    cp = subprocess.run(
        ["tmux", "capture-pane", "-t", sn, "-p", "-S", f"-{lines}"],
        capture_output=True,
        text=True,
    )
    return cp.stdout if cp.returncode == 0 else ""


def tmux_list() -> list[str]:
    cp = subprocess.run(
        ["tmux", "list-sessions", "-F", "#{session_name}"],
        capture_output=True,
        text=True,
    )
    if cp.returncode != 0:
        return []
    return [ln.removeprefix(TMUX_PREFIX) for ln in cp.stdout.strip().splitlines() if ln.startswith(TMUX_PREFIX)]


# ---------------------------------------------------------------------------
# Status detection
# ---------------------------------------------------------------------------

_ANSI_RE = re.compile(r"\x1b\[[0-9;]*[A-Za-z]")


def _strip_ansi(text: str) -> str:
    return _ANSI_RE.sub("", text)


def _at_shell_prompt(line: str) -> bool:
    stripped = line.rstrip()
    return bool(stripped) and stripped[-1] in ("$", "%", "#")


_APPROVAL_PATTERNS = [
    "approve",
    "allow",
    "permit",
    "yes/no",
    "y/n",
    "press enter",
    "confirm",
    "accept",
    "do you want to",
    "proceed",
]

_ERROR_PATTERNS = ["traceback", "error:", "fatal:", "exception:", "panic:"]

_WORKING_PATTERNS = [
    "thinking",
    "generating",
    "writing",
    "reading",
    "running",
    "searching",
    "executing",
    "analyzing",
]


def _detect_status(output: str) -> str:
    if not output or not output.strip():
        return "unknown"

    clean = _strip_ansi(output)
    lines = clean.strip().splitlines()
    if not lines:
        return "unknown"

    tail = "\n".join(lines[-30:]).lower()
    last_line = lines[-1].strip()

    if _at_shell_prompt(last_line):
        return "exited"

    for pat in _APPROVAL_PATTERNS:
        if pat in tail:
            return "waiting"

    for pat in _ERROR_PATTERNS:
        if pat in tail:
            return "error"

    for pat in _WORKING_PATTERNS:
        if pat in tail:
            return "working"

    if last_line:
        return "idle"

    return "unknown"


# ---------------------------------------------------------------------------
# Alerts
