# ---------------------------------------------------------------------------
# REST API
# ---------------------------------------------------------------------------


class APIHandler(BaseHTTPRequestHandler):
    def log_message(self, fmt: str, *fmt_args: Any) -> None:
        LOG.debug(fmt, *fmt_args)

    def _cors(self) -> None:
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Methods", "GET,POST,DELETE,OPTIONS")
        self.send_header("Access-Control-Allow-Headers", "Content-Type")

    def _json(self, data: Any, status: int = 200) -> None:
        body = json.dumps(data, default=str).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self._cors()
        self.end_headers()
        self.wfile.write(body)

    def _html(self, html: str) -> None:
        body = html.encode()
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self._cors()
        self.end_headers()
        self.wfile.write(body)

    def _read_body(self) -> dict[str, Any]:
        length = int(self.headers.get("Content-Length", 0))
        if length == 0:
            return {}
        return json.loads(self.rfile.read(length))

    def _route(self) -> tuple[str, list[str]]:
        path = self.path.split("?")[0].rstrip("/")
        parts = [p for p in path.split("/") if p]
        return path, parts

    def do_OPTIONS(self) -> None:  # noqa: N802
        self.send_response(204)
        self._cors()
        self.end_headers()

    def do_GET(self) -> None:  # noqa: N802
        path, parts = self._route()
        conn = _db()

        if path == "" or path == "/":
            self._html(DASHBOARD_HTML)
            return

        if path == "/api/sessions":
            rows = _rows_list(conn.execute("SELECT * FROM sessions ORDER BY name").fetchall())
            self._json(rows)
            return

        if len(parts) == 3 and parts[0] == "api" and parts[1] == "sessions":
            name = parts[2]
            try:
                name = resolve_name(name)
            except SystemExit:
                self._json({"error": "not found"}, 404)
                return
            row = _row_dict(conn.execute("SELECT * FROM sessions WHERE name = ?", (name,)).fetchone())
            self._json(row)
            return

        if len(parts) == 4 and parts[0] == "api" and parts[1] == "sessions" and parts[3] == "peek":
            name = parts[2]
            try:
                name = resolve_name(name)
            except SystemExit:
                self._json({"error": "not found"}, 404)
                return
            output = tmux_capture(name)
            status = _detect_status(output)
            self._json({"name": name, "status": status, "output": output})
            return

        if len(parts) == 4 and parts[0] == "api" and parts[1] == "sessions" and parts[3] == "status":
            name = parts[2]
            try:
                name = resolve_name(name)
            except SystemExit:
                self._json({"error": "not found"}, 404)
                return
            output = tmux_capture(name, lines=40)
            status = _detect_status(output)
            self._json({"name": name, "status": status})
            return

        if path == "/api/tasks":
            rows = _rows_list(conn.execute("SELECT * FROM tasks ORDER BY created_at").fetchall())
            self._json(rows)
            return

        if path == "/api/memory":
            rows = _rows_list(conn.execute("SELECT * FROM memory ORDER BY key").fetchall())
            self._json(rows)
            return

        if path == "/api/messages":
            rows = _rows_list(conn.execute("SELECT * FROM messages ORDER BY id DESC LIMIT 200").fetchall())
            self._json(rows)
            return

        if path == "/api/alerts":
            rows = _rows_list(conn.execute("SELECT * FROM alerts ORDER BY id DESC LIMIT 100").fetchall())
            self._json(rows)
            return

        self._json({"error": "not found"}, 404)

    def do_POST(self) -> None:  # noqa: N802
        path, parts = self._route()
        conn = _db()

        if len(parts) == 4 and parts[0] == "api" and parts[1] == "sessions" and parts[3] == "start":
            name = parts[2]
            try:
                name = resolve_name(name)
            except SystemExit:
                self._json({"error": "not found"}, 404)
                return
            ns = argparse.Namespace(name=name, prompt=None)
            result = cmd_start(ns)
            self._json(result)
            return

        if len(parts) == 4 and parts[0] == "api" and parts[1] == "sessions" and parts[3] == "stop":
            name = parts[2]
            try:
                name = resolve_name(name)
            except SystemExit:
                self._json({"error": "not found"}, 404)
                return
            ns = argparse.Namespace(name=name)
            result = cmd_stop(ns)
            self._json(result)
            return

        if len(parts) == 4 and parts[0] == "api" and parts[1] == "sessions" and parts[3] == "send":
            name = parts[2]
            try:
                name = resolve_name(name)
            except SystemExit:
                self._json({"error": "not found"}, 404)
                return
            body = self._read_body()
            text = body.get("text", "")
            if not text:
                self._json({"error": "missing text"}, 400)
                return
            ns = argparse.Namespace(name=name, text=text)
            result = cmd_send(ns)
            self._json(result)
            return

        if path == "/api/tasks":
            body = self._read_body()
            title = body.get("title", "")
            if not title:
                self._json({"error": "missing title"}, 400)
                return
            tid = _short_id()
            now = _now()
            conn.execute(
                "INSERT INTO tasks (id, title, status, created_at, updated_at) VALUES (?,?,?,?,?)",
                (tid, title, "todo", now, now),
            )
            conn.commit()
            self._json({"id": tid, "title": title, "status": "todo"})
            return

        if len(parts) == 4 and parts[0] == "api" and parts[1] == "tasks" and parts[3] == "claim":
            tid = parts[2]
            body = self._read_body()
            assignee = body.get("assignee", "web")
            now = _now()
            conn.execute(
                "UPDATE tasks SET status='claimed', assignee=?, updated_at=? WHERE id=?",
                (assignee, now, tid),
            )
            conn.commit()
            self._json({"id": tid, "status": "claimed"})
            return

        if len(parts) == 4 and parts[0] == "api" and parts[1] == "tasks" and parts[3] == "done":
            tid = parts[2]
            now = _now()
            conn.execute(
                "UPDATE tasks SET status='done', updated_at=? WHERE id=?",
                (now, tid),
            )
            conn.commit()
            self._json({"id": tid, "status": "done"})
            return

        if path == "/api/memory":
            body = self._read_body()
            key = body.get("key", "")
            value = body.get("value", "")
            if not key:
                self._json({"error": "missing key"}, 400)
                return
            now = _now()
            conn.execute(
                """INSERT INTO memory (key, value, updated_at) VALUES (?,?,?)
                   ON CONFLICT(key) DO UPDATE SET value=excluded.value, updated_at=excluded.updated_at""",
                (key, value, now),
            )
            conn.commit()
            self._json({"key": key, "value": value})
            return

        self._json({"error": "not found"}, 404)

    def do_DELETE(self) -> None:  # noqa: N802
        path, parts = self._route()
        conn = _db()

        if len(parts) == 3 and parts[0] == "api" and parts[1] == "sessions":
            name = parts[2]
            try:
                name = resolve_name(name)
            except SystemExit:
                self._json({"error": "not found"}, 404)
                return
            tmux_kill_session(name)
            conn.execute("DELETE FROM sessions WHERE name = ?", (name,))
            conn.commit()
            self._json({"deleted": name})
            return

        if len(parts) == 3 and parts[0] == "api" and parts[1] == "memory":
            key = parts[2]
            conn.execute("DELETE FROM memory WHERE key = ?", (key,))
            conn.commit()
            self._json({"deleted": key})
            return

        self._json({"error": "not found"}, 404)


# ---------------------------------------------------------------------------
# TLS
# ---------------------------------------------------------------------------


def ensure_tls(cert_dir: Path) -> tuple[str, str] | None:
    cert_dir.mkdir(parents=True, exist_ok=True)
    cert_file = cert_dir / "cert.pem"
    key_file = cert_dir / "key.pem"

    if cert_file.exists() and key_file.exists():
        return str(cert_file), str(key_file)

    try:
        subprocess.run(
            [
                "mkcert",
                "-cert-file",
                str(cert_file),
                "-key-file",
                str(key_file),
                "localhost",
                "127.0.0.1",
            ],
            check=True,
            capture_output=True,
        )
        return str(cert_file), str(key_file)
    except (FileNotFoundError, subprocess.CalledProcessError):
        pass

    try:
        subprocess.run(
            [
                "openssl",
                "req",
                "-x509",
                "-newkey",
                "rsa:2048",
                "-keyout",
                str(key_file),
                "-out",
                str(cert_file),
                "-days",
                "365",
                "-nodes",
                "-subj",
                "/CN=localhost",
            ],
            check=True,
            capture_output=True,
        )
        return str(cert_file), str(key_file)
    except (FileNotFoundError, subprocess.CalledProcessError):
        LOG.warning("Could not generate TLS certificates; running without TLS")
        return None


# ---------------------------------------------------------------------------
# cmd_serve
# ---------------------------------------------------------------------------


def cmd_serve(args: argparse.Namespace) -> None:
    port = getattr(args, "port", DEFAULT_PORT) or DEFAULT_PORT
    use_tls = getattr(args, "tls", False)

    _db()

    wd = threading.Thread(target=watchdog_loop, daemon=True)
    wd.start()

    server = HTTPServer(("0.0.0.0", port), APIHandler)

    scheme = "http"
    if use_tls:
        tls = ensure_tls(DATA_DIR / "tls")
        if tls:
            ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
            ctx.load_cert_chain(tls[0], tls[1])
            server.socket = ctx.wrap_socket(server.socket, server_side=True)
            scheme = "https"

    banner = (
        f"\n  codexmux v{VERSION}\n"
        f"  Dashboard: {scheme}://localhost:{port}/\n"
        f"  API:       {scheme}://localhost:{port}/api/sessions\n"
        f"  Watchdog:  running\n"
    )
    print(banner)

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nShutting down.")
        server.shutdown()


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="codexmux",
        description="Codex CLI Multiplexer",
    )
    parser.add_argument("--version", action="version", version=f"codexmux {VERSION}")
    sub = parser.add_subparsers(dest="command")

    # register
    p_reg = sub.add_parser("register", help="Register a session")
    p_reg.add_argument("name")
    p_reg.add_argument("--dir", default=None)
    p_reg.add_argument("--full-auto", action="store_true")
    p_reg.add_argument("--model", default=None)
    p_reg.add_argument("--sandbox", default=None)

    # start
    p_start = sub.add_parser("start", help="Start a session")
    p_start.add_argument("name")
    p_start.add_argument("--prompt", default=None)

    # update
    p_upd = sub.add_parser("update", aliases=["set"], help="Update session settings")
    p_upd.add_argument("name")
    p_upd.add_argument("--dir", default=None, help="Change working directory")
    p_upd.add_argument("--full-auto", action="store_true", default=None, help="Enable full-auto")
    p_upd.add_argument("--no-full-auto", action="store_true", default=False, help="Disable full-auto")
    p_upd.add_argument("--model", default=None, help="Change model")
    p_upd.add_argument("--sandbox", default=None, help="Change sandbox mode")

    # stop
    p_stop = sub.add_parser("stop", help="Stop a session")
    p_stop.add_argument("name")

    # rm
    p_rm = sub.add_parser("rm", aliases=["remove", "del"], help="Remove a session")
    p_rm.add_argument("name")

    # attach
    p_attach = sub.add_parser("attach", help="Attach to a session")
    p_attach.add_argument("name")

    # peek
    p_peek = sub.add_parser("peek", help="Peek at session output")
    p_peek.add_argument("name")
    p_peek.add_argument("--json", dest="json_output", action="store_true")

    # send
    p_send = sub.add_parser("send", help="Send text to a session")
    p_send.add_argument("name")
    p_send.add_argument("text")

    # exec
    p_exec = sub.add_parser("exec", help="Register + start + send in one shot")
    p_exec.add_argument("name")
    p_exec.add_argument("--dir", default=None)
    p_exec.add_argument("--full-auto", action="store_true")
    p_exec.add_argument("--model", default=None)
    p_exec.add_argument("--sandbox", default=None)
    p_exec.add_argument("--prompt", default=None)

    # ls
    p_ls = sub.add_parser("ls", help="List sessions")
    p_ls.add_argument("--format", choices=["text", "json"], default="text")

    # board
    p_board = sub.add_parser("board", help="Task board")
    board_sub = p_board.add_subparsers(dest="board_action")

    p_ba = board_sub.add_parser("add", help="Add a task")
    p_ba.add_argument("title")

    p_bc = board_sub.add_parser("claim", help="Claim a task")
    p_bc.add_argument("id")
    p_bc.add_argument("--assignee", default="cli")

    p_bd = board_sub.add_parser("done", help="Mark task done")
    p_bd.add_argument("id")

    board_sub.add_parser("list", help="List tasks")

    # serve
    p_serve = sub.add_parser("serve", help="Start the web server")
    p_serve.add_argument("--port", type=int, default=DEFAULT_PORT)
    p_serve.add_argument("--tls", action="store_true")

    return parser


def main() -> None:
    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s %(levelname)s %(name)s: %(message)s",
    )

    parser = build_parser()
    args = parser.parse_args()

    if args.command is None:
        parser.print_help()
        raise SystemExit(1)

    dispatch = {
        "register": cmd_register,
        "update": cmd_update,
        "set": cmd_update,
        "start": cmd_start,
        "stop": cmd_stop,
        "rm": cmd_rm,
        "remove": cmd_rm,
        "del": cmd_rm,
        "attach": cmd_attach,
        "peek": cmd_peek,
        "send": cmd_send,
        "exec": cmd_exec,
        "ls": cmd_ls,
        "board": cmd_board,
        "serve": cmd_serve,
    }

    fn = dispatch.get(args.command)
    if fn is None:
        parser.print_help()
        raise SystemExit(1)

    fn(args)


if __name__ == "__main__":
    main()
