<script>
const BASE = '';
let peekName = null;
let peekTimer = null;

function switchTab(name) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelector('.tab[onclick*="'+name+'"]').classList.add('active');
  document.getElementById('panel-'+name).classList.add('active');
}

async function api(path, opts) {
  const r = await fetch(BASE + path, opts);
  return r.json();
}

async function loadSessions() {
  const ss = await api('/api/sessions');
  const el = document.getElementById('session-cards');
  el.innerHTML = ss.map(s => {
    const flags = [];
    if (s.full_auto) flags.push('full-auto');
    if (s.model) flags.push('model='+s.model);
    if (s.sandbox) flags.push('sandbox='+s.sandbox);
    return '<div class="card">'+
      '<div class="card-head"><div class="dot '+s.status+'"></div><span class="card-name">'+s.name+'</span><span style="color:var(--text-dim);font-size:.8rem;margin-left:auto">'+s.status+'</span></div>'+
      '<div class="flags">'+flags.map(f=>'<span class="flag">'+f+'</span>').join('')+'</div>'+
      '<div class="card-actions">'+
        '<button class="btn" onclick="openPeek(\''+s.name+'\')">Peek</button>'+
        (s.status==='stopped'?'<button class="btn" onclick="startSession(\''+s.name+'\')">Start</button>':'')+
        (s.status!=='stopped'?'<button class="btn danger" onclick="stopSession(\''+s.name+'\')">Stop</button>':'')+
      '</div></div>';
  }).join('');
}

async function startSession(n) { await api('/api/sessions/'+n+'/start', {method:'POST'}); loadSessions(); }
async function stopSession(n) { await api('/api/sessions/'+n+'/stop', {method:'POST'}); loadSessions(); }

async function openPeek(n) {
  peekName = n;
  document.getElementById('peek-title').textContent = n;
  document.getElementById('peek-modal').classList.add('active');
  refreshPeek();
  peekTimer = setInterval(refreshPeek, 3000);
}

function closePeek() {
  document.getElementById('peek-modal').classList.remove('active');
  peekName = null;
  if (peekTimer) { clearInterval(peekTimer); peekTimer = null; }
}

async function refreshPeek() {
  if (!peekName) return;
  const d = await api('/api/sessions/'+peekName+'/peek');
  document.getElementById('peek-output').textContent = d.output || '';
  const el = document.querySelector('.modal-body');
  el.scrollTop = el.scrollHeight;
}

async function sendToPeek() {
  const inp = document.getElementById('peek-send');
  const text = inp.value.trim();
  if (!text || !peekName) return;
  await api('/api/sessions/'+peekName+'/send', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({text})
  });
  inp.value = '';
  setTimeout(refreshPeek, 500);
}

async function loadTasks() {
  const tasks = await api('/api/tasks');
  ['todo','claimed','done'].forEach(st => {
    const col = document.getElementById('col-'+st);
    col.innerHTML = tasks.filter(t=>t.status===st).map(t =>
      '<div class="task-card"><div class="task-id">'+t.id+'</div>'+t.title+'</div>'
    ).join('');
  });
}

async function addTask() {
  const inp = document.getElementById('task-input');
  const title = inp.value.trim();
  if (!title) return;
  await api('/api/tasks', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({title})
  });
  inp.value = '';
  loadTasks();
}

async function loadAlerts() {
  const alerts = await api('/api/alerts');
  const el = document.getElementById('alerts-list');
  el.innerHTML = alerts.map(a =>
    '<div class="alert-item"><span class="alert-time">'+a.created_at.replace('T',' ').slice(0,19)+'</span><span class="alert-type">'+a.type+'</span><span>'+a.message+'</span></div>'
  ).join('') || '<div style="color:var(--text-dim)">No alerts.</div>';
}

function refresh() { loadSessions(); loadTasks(); loadAlerts(); }
refresh();
setInterval(refresh, 5000);
</script>
